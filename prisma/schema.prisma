generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuoteMode {
  OAT_DIRECT
  KEENER_LOGISTICS
  OAT_IF_BROKERED
}

enum QuoteStatus {
  DRAFT
  IMPORTED_FROM_GHL
  READY_TO_SEND
  PDF_GENERATED
  SYNCED_TO_GHL
  SENT
  VIEWED
  QUESTION
  ACCEPTED
  DECLINED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum QuoteCustomerMessageType {
  QUESTION
}

enum NotificationType {
  QUOTE_ACCEPTED
  QUOTE_DECLINED
  QUOTE_QUESTION
}

enum FeeType {
  CARRIER_PAY
  BROKER_FEE
  FUEL_SURCHARGE
  INOPERABLE_FEE
  ENCLOSED_FEE
  OVERSIZED_FEE
  EXPEDITED_FEE
  STORAGE_FEE
  RESIDENTIAL_PICKUP_FEE
  HARD_TO_ACCESS_LOCATION_FEE
  DISCOUNT
  CUSTOM
}

enum GhlSyncDirection {
  GHL_TO_APP
  APP_TO_GHL
}

enum GhlSyncStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

model Company {
  id           String   @id @default(cuid())
  name         String
  legalName    String
  logoUrl      String?
  iconUrl      String?
  phone        String?
  email        String?
  website      String?
  address      String?
  dotNumber    String?
  mcNumber     String?
  defaultTerms String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotes Quote[]
}

model CustomerSnapshot {
  id               String   @id @default(cuid())
  ghlContactId     String?
  ghlOpportunityId String?
  name             String
  phone            String?
  email            String?
  companyName      String?
  rawGhlData       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  quotes Quote[]

  @@index([ghlContactId])
  @@index([ghlOpportunityId])
  @@index([createdAt])
}

model Quote {
  id                          String      @id @default(cuid())
  quoteNumber                 String      @unique
  quoteMode                   QuoteMode
  status                      QuoteStatus @default(DRAFT)
  companyId                   String
  customerSnapshotId          String
  pickupAddress               String?
  pickupCity                  String?
  pickupState                 String?
  pickupZip                   String?
  pickupContactName           String?
  pickupContactPhone          String?
  deliveryAddress             String?
  deliveryCity                String?
  deliveryState               String?
  deliveryZip                 String?
  deliveryContactName         String?
  deliveryContactPhone        String?
  pickupDate                  DateTime?
  deliveryWindow              String?
  trailerType                 String?
  customerTotal               Decimal     @db.Decimal(10, 2)
  depositDue                  Decimal     @default(0) @db.Decimal(10, 2)
  balanceDue                  Decimal     @default(0) @db.Decimal(10, 2)
  internalEstimatedCarrierPay Decimal?    @db.Decimal(10, 2)
  internalGrossMargin         Decimal?    @db.Decimal(10, 2)
  internalMarginPercentage    Decimal?    @db.Decimal(7, 4)
  quotePdfUrl                 String?
  acceptanceUrl               String?
  secureAccessToken           String      @unique
  ghlContactId                String?
  ghlOpportunityId            String?
  ghlLocationId               String?
  ghlPipelineId               String?
  ghlStageId                  String?
  customerNotes               String?     @db.Text
  internalNotes               String?     @db.Text
  validUntil                  DateTime?
  acceptedAt                  DateTime?
  declinedAt                  DateTime?
  declineReason               String?     @db.Text
  customerSignature           String?
  acceptedIp                  String?
  acceptedUserAgent           String?     @db.Text
  declinedIp                  String?
  declinedUserAgent           String?     @db.Text
  lastCustomerActionAt        DateTime?
  archivedAt                  DateTime?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  company          Company                @relation(fields: [companyId], references: [id])
  customerSnapshot CustomerSnapshot       @relation(fields: [customerSnapshotId], references: [id])
  vehicles         VehicleSnapshot[]
  fees             QuoteFee[]
  events           QuoteEvent[]
  ghlSyncLogs      GhlSyncLog[]
  customerMessages QuoteCustomerMessage[]
  notifications    Notification[]

  @@index([quoteNumber])
  @@index([ghlContactId])
  @@index([ghlOpportunityId])
  @@index([ghlLocationId])
  @@index([status])
  @@index([quoteMode])
  @@index([createdAt])
  @@index([archivedAt])
}

model VehicleSnapshot {
  id             String   @id @default(cuid())
  quoteId        String
  year           String?
  make           String?
  model          String?
  type           String?
  condition      String?
  vin            String?
  isRunning      Boolean?
  notes          String?  @db.Text
  rawVehicleData Json?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteFee {
  id             String  @id @default(cuid())
  quoteId        String
  feeType        FeeType
  label          String
  amount         Decimal @db.Decimal(10, 2)
  isEnabled      Boolean @default(true)
  showOnPdf      Boolean @default(true)
  isInternalOnly Boolean @default(false)
  internalNote   String? @db.Text
  sortOrder      Int     @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([feeType])
}

model QuoteEvent {
  id        String   @id @default(cuid())
  quoteId   String
  type      String
  message   String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([type])
  @@index([createdAt])
}

model QuoteCustomerMessage {
  id           String                   @id @default(cuid())
  quoteId      String
  type         QuoteCustomerMessageType @default(QUESTION)
  customerName String
  message      String                   @db.Text
  ipAddress    String?
  userAgent    String?                  @db.Text
  createdAt    DateTime                 @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  quoteId   String
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([isRead])
  @@index([createdAt])
}

model GhlFieldMapping {
  id                 String   @id @default(cuid())
  ghlLocationId      String
  appFieldKey        String
  ghlCustomFieldId   String?
  ghlCustomFieldName String?
  fallbackPath       String?
  isRequired         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([ghlLocationId, appFieldKey])
  @@index([ghlLocationId])
  @@index([appFieldKey])
}

model GhlSyncLog {
  id              String           @id @default(cuid())
  quoteId         String?
  direction       GhlSyncDirection
  status          GhlSyncStatus
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?          @db.Text
  createdAt       DateTime         @default(now())

  quote Quote? @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([direction])
  @@index([status])
  @@index([createdAt])
}
